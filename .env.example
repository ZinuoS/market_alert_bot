# ── Claude API ───────────────────────────────────────────
# Only needed if you're running main.py (Claude-powered version)
# Get a key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ntfy ─────────────────────────────────────────────────
# This is your notification "channel". Pick something unguessable —
# anyone who knows the topic name can subscribe to your feed.
# e.g. market-john-x7k2q9m4nz
NTFY_TOPIC=market-yourname-randomstring
NTFY_SERVER=https://ntfy.sh

# ── Schedule (24h ET) ────────────────────────────────────
SCHEDULE_ASIA_WRAP=05:30
SCHEDULE_EU_OPEN=07:30
SCHEDULE_US_OPEN=09:25
SCHEDULE_US_CLOSE=16:05

# ── Breaking news thresholds ─────────────────────────────
# New headlines required to trigger a breaking alert
BREAKING_NEWS_THRESHOLD=3
# % move on any major index to count as significant
INDEX_MOVE_THRESHOLD=1.5
# Minutes to wait before sending another breaking alert
BREAKING_COOLDOWN_MIN=30
